{
  "info": {
    "_postman_id": "00000000-0000-0000-0000-api-troubleshooting-lab",
    "name": "API Troubleshooting Lab",
    "description": "Clean demo collection for the API Troubleshooting Lab. Covers success paths, authentication failures, validation failures, backend failure simulation, and gateway behaviour.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "lab-demo-key",
      "type": "string"
    },
    {
      "key": "request_id",
      "value": "postman-demo-{{$timestamp}}",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "01 - Success Path",
      "item": [
        {
          "name": "Create Order - Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-API-Key",
                "value": "{{api_key}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/xml",
                "type": "text"
              },
              {
                "key": "X-Request-ID",
                "value": "{{request_id}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "<Order>\n  <CustomerID>12345</CustomerID>\n  <ProductID>ABC123</ProductID>\n  <Quantity>2</Quantity>\n</Order>",
              "options": {
                "raw": {
                  "language": "xml"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/orders",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Expected result: 201 Created. Order is created through the gateway and backend."
          },
          "response": []
        }
      ]
    },
